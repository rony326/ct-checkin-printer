# ── ChurchTools ───────────────────────────────────────────────
CT_BASE_URL=https://meinegemeinde.church.tools
CT_USERNAME=drucker@meinegemeinde.de
CT_PASSWORD=sicheresPasswort

# ── Drucker & Layout ──────────────────────────────────────────
PRINTERS_FILE=./printers.json
LABEL_TYPE=54                      # brother_ql Label-Identifier
LAYOUT_FILE=./label-layout.json    # Layout-Konfiguration
MAPPING_FILE=./field-mapping.json  # Feld-Mapping CT → intern
# DRY_RUN=true                     # Nur PNG rendern, nicht drucken

# ── Polling ───────────────────────────────────────────────────
POLL_IDLE_MS=15000
POLL_ACTIVE_MS=5000
POLL_ACTIVE_TTL_MS=300000

# ── Zeitfenster ───────────────────────────────────────────────
# ACTIVE_TIMES=So:09:00-12:00 18:00-20:00

# ── Fehlerbehandlung & Logging ────────────────────────────────
MAX_ERRORS=10
LOG_LEVEL=info

# ── Webhook ───────────────────────────────────────────────────
# Konfiguration der Webhook-Ziele in webhooks.json
# WEBHOOKS_FILE=./webhooks.json      # Pfad zur Webhook-Konfiguration
# WEBHOOKS_ENABLED=true              # false = alle Webhooks deaktivieren
# WEBHOOK_RETRY=3                    # globaler Default (pro Eintrag überschreibbar)
# WEBHOOK_RETRY_MS=2000              # Wartezeit zwischen Versuchen in ms
# WEBHOOK_BLOCK_PRINT=false          # true = Druck wartet auf Webhook-Erfolg
